[
  {
    "title": "Lesson 1:\nI have, You have",
    "description": "'Tener' (to have) is crucial. 'Tengo' = I have, 'Tienes' = you have. Also used for age in Spanish (I have 5 years = I am 5 years old).",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "Yo tengo un perro.",
        "english": "I have a dog."
      },
      {
        "speaker": "B",
        "gender": "male",
        "spanish": "¿Sí? Yo tengo un gato.",
        "english": "Really? I have a cat."
      },
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "¿Tú tienes hermanos?",
        "english": "Do you have siblings?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "spanish": "Sí, tengo dos hermanos.",
        "english": "Yes, I have two brothers."
      }
    ]
  },
  {
    "title": "Lesson 2:\nI like",
    "description": "'Me gusta' = I like (literally 'it pleases me'). This verb works differently - 'gusta' for singular, 'gustan' for plural. Very common expression!",

      },
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "Estoy en España.",
        "english": "I am in Spain."
      },
      {
        "speaker": "B",
        "gender": "male",
        "spanish": "España es bonita.",
        "english": "Spain is beautiful."
      },
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "Sí, y estoy muy contento aquí.",
        "english": "Yes, and I am very happy here."

      {
        "speaker": "B",
        "gender": "male",
        "spanish": "Sí, siempre como desayuno.",
        "english": "Yes, I always eat breakfast."
      },
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "Yo a veces no como.",
        "english": "I sometimes don't eat."
      },
      {
        "speaker": "B",
        "gender": "male",
        "spanish": "Nunca salto el desayuno.",
        "english": "I never skip breakfast."

        "speaker": "B",
        "gender": "male",
        "spanish": "Sí, hay un banco en la calle.",
        "english": "Yes, there is a bank on the street."
      },
      {
        "speaker": "A",
        "gender": "female",
        "spanish": "¿Hay restaurantes aquí?",
        "english": "Are there restaurants here?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "spanish": "Sí, hay muchos restaurantes.",
        "english": "Yes, there are many restaurants."
      }

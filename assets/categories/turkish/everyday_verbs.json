  {
    "title": "Lesson 12:\nTo know (facts)",
    "description": "'Bilmek' (to know facts/information): 'biliyorum' = I know, 'biliyorsun' = you know.",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Bankanın nerede olduğunu biliyor musun?",
        "english": "Do you know where the bank is?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, bilmiyorum.",
        "english": "No, I don't know."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "İngilizce biliyor musun?",
        "english": "Do you know how to speak English?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, İngilizce biliyorum.",
        "english": "Yes, I know how to speak English."
      }
    ]
  },
  {
    "title": "Lesson 13:\nTo know (people/places)",
    "description": "'Tanımak' (to know people/be familiar with): 'tanıyorum' = I know, 'tanıyorsun' = you know. Different from 'bilmek'!",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ayşe'yi tanıyor musun?",
        "english": "Do you know Ayşe?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, Ayşe'yi tanıyorum.",
        "english": "Yes, I know Ayşe."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "İstanbul'u tanıyor musun?",
        "english": "Do you know Istanbul?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, İstanbul'u tanımıyorum.",
        "english": "No, I don't know Istanbul."
      }
    ]
  },
  {
    "title": "Lesson 14:\nTo be able/can",
    "description": "'Abilmek/ebilmek' (can/to be able): 'yapabilirim' = I can do. Suffix added to verb stems.",

      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Yarın gelebilir misin?",
        "english": "Can you come tomorrow?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, yarın gelemem.",

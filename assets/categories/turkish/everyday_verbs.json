      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, her gün televizyon izlerim.",
        "english": "Yes, I watch television every day."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ne izlersin?",
        "english": "What do you watch?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Film ve dizi izlerim.",
        "english": "I watch movies and series."
      }
    ]
  },
  {
    "title": "Lesson 9:\nTo open/close",
    "description": "'Açmak' (to open): 'açıyorum' = I open. 'Kapamak' (to close): 'kapatıyorum' = I close.",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Dükkan saat kaçta açılıyor?",
        "english": "What time do they open the store?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Dokuzda açılıyor.",
        "english": "They open at nine."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ne zaman kapanıyor?",
        "english": "And when do they close?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Sekizde kapanıyor.",
        "english": "They close at eight."
      }
    ]
  },
  {

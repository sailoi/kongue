      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, bilmiyorum.",
        "english": "No, I don't know."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "İngilizce biliyor musun?",
        "english": "Do you know how to speak English?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, İngilizce biliyorum.",
        "english": "Yes, I know how to speak English."
      }
    ],
    "vocabulary": [
      {
        "turkish": "biliyorum",

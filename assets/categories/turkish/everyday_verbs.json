      },
      {
        "turkish": "banka",
        "english": "bank"
      },
      {
        "turkish": "hayır",
        "english": "no"
      }
    ]
  },
  {
    "title": "Lesson 13:\nTo know (people/places)",
    "description": "'Tanımak' (to know people/be familiar with): 'tanıyorum' = I know, 'tanıyorsun' = you know. Different from 'bilmek'!",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ayşe'yi tanıyor musun?",
        "english": "Do you know Ayşe?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, Ayşe'yi tanıyorum.",
        "english": "Yes, I know Ayşe."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "İstanbul'u tanıyor musun?",
        "english": "Do you know Istanbul?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, İstanbul'u tanımıyorum.",
        "english": "No, I don't know Istanbul."
      }
    ],
    "vocabulary": [
      {
        "turkish": "tanıyorum",
        "english": "I know (person/place)"
      },
      {
        "turkish": "tanımıyorum",
        "english": "I don't know (person/place)"
      },
      {
        "turkish": "şehir",
        "english": "city"
      },
      {
        "turkish": "tanımak",
        "english": "to know (people/places)"
      }
    ]
  },
  {

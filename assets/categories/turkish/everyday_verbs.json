        "gender": "female",
        "turkish": "Ben de severim.",
        "english": "I like it too."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Sporları sever misin?",
        "english": "Do you like sports?"
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Evet, sporları severim.",
        "english": "Yes, I like sports."
      }
    ],
    "vocabulary": [
      {
        "turkish": "severim",
        "english": "I like"
      },
      {
        "turkish": "sever misin?",
        "english": "do you like?"
      },
      {
        "turkish": "futbol",
        "english": "soccer"
      },
      {
        "turkish": "spor",
        "english": "sports"
      }
    ]
  },

      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, her zaman kahvaltı ederim.",
        "english": "Yes, I always eat breakfast."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ben bazen yemem.",
        "english": "I sometimes don't eat."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Asla kahvaltıyı atlamam.",
        "english": "I never skip breakfast."
      }
    ]
  },

        "gender": "female",
        "turkish": "Ben Türkiye'denim.",
        "english": "I am from Turkey."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Şimdi neredesin?",
        "english": "Where are you now?"
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "İspanya'dayım.",
        "english": "I am in Spain."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "İspanya güzel.",
        "english": "Spain is beautiful."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Evet, burada çok mutluyum.",
        "english": "Yes, and I am very happy here."
      }
    ]
  },
  {
    "title": "Lesson 6:\nFrequency adverbs",
    "description": "Frequency words: her zaman (always), asla (never), bazen (sometimes), genellikle (generally), her gün (every day).",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Her zaman kahvaltı eder misin?",

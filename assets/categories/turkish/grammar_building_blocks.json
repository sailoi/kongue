        "gender": "female",
        "turkish": "Fransızca konuşur musun?",
        "english": "Do you speak French?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, Fransızca konuşmam.",
        "english": "No, I don't speak French."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Et yer misin?",
        "english": "Do you eat meat?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, et yemem.",
        "english": "No, I don't eat meat."
      }

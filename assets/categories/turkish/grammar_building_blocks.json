  {
    "title": "Lesson 2:\nQuestion words review",
    "description": "Key question words: Ne? (what), Kim? (who), Nerede? (where), Ne zaman? (when), Neden? (why), Nasıl? (how), Ne kadar? (how much).",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Ne yapıyorsun?",
        "english": "What are you doing?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Çalışıyorum. Ayşe nerede?",
        "english": "I'm studying. Where is Ayşe?"
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Evde. Ne zaman gidiyorsun?",
        "english": "She's at home. When are you going?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Yarın gidiyorum.",
        "english": "I'm going tomorrow."
      }
    ]
  },
  {
    "title": "Lesson 3:\nNegation",
    "description": "To make a sentence negative, add '-me/-ma' or '-mı/-mu' to the verb. 'Konuşmuyorum' = I don't speak.",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Fransızca konuşur musun?",
        "english": "Do you speak French?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, Fransızca konuşmam.",
        "english": "No, I don't speak French."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Et yer misin?",
        "english": "Do you eat meat?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Hayır, et yemem.",
        "english": "No, I don't eat meat."
      }
    ]
  },
  {
    "title": "Lesson 4:\nMy, your, his, her",
    "description": "Possessive suffixes: -im/-ım (my), -in/-ın (your), -i/-ı (his/her/its). 'Kitabım' = my book, 'Kitabın' = your book.",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Bu benim kitabım.",
        "english": "This is my book."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Çantan nerede?",
        "english": "Where is your backpack?"
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Çantam burada.",
        "english": "My backpack is here."
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Kitapları masada.",
        "english": "His/Her books are on the table."
      }
    ]
  },
  {
    "title": "Lesson 5:\nBeing review",
    "description": "Turkish uses suffix '-dir/-dır/-dur/-dür' for permanent states and location words for temporary location.",

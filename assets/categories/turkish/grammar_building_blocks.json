    "title": "Lesson 1:\nThere is/are",
    "description": "'Var' means both 'there is' and 'there are'. Very useful for describing what exists or is available.",
    "dialogue": [
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Yakında banka var mı?",
        "english": "Is there a bank nearby?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, caddede bir banka var.",
        "english": "Yes, there is a bank on the street."
      },
      {
        "speaker": "A",
        "gender": "female",
        "turkish": "Burada restoranlar var mı?",
        "english": "Are there restaurants here?"
      },
      {
        "speaker": "B",
        "gender": "male",
        "turkish": "Evet, çok restoran var.",
        "english": "Yes, there are many restaurants."
      }
    ]
